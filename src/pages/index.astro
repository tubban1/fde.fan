---
import SiteLayout from "../layouts/SiteLayout.astro";
import { aiFdeLoop, assessmentLevels, boundaryItems, industryLabs, learningTracks, outcomes, stats, weekPath } from "../data/site";

const allianceMembers = [
  { name: "TG Technologie", image: "/assets/alliance/tg-technologie.png", type: "logo" },
  { name: "WeOPC", image: "/assets/alliance/weopc.png", type: "logo" },
  { name: "Bin Altman", org: "TG Technologies", image: "/assets/alliance/bin-altman.png", type: "avatar" },
  { name: "Ziyange", org: "TG Technologies", image: "/assets/alliance/ziyange.png", type: "avatar" },
  { name: "Shawn Von", org: "TG Technologies", image: "/assets/alliance/shawn-von.png", type: "avatar" },
  { name: "Liang Rao", org: "FDE FAN Alliance", image: "/assets/alliance/liang-rao.png", type: "avatar" },
  { name: "Beckwen", org: "Kuaishou", image: "/assets/alliance/beckwen.png", type: "avatar" },
  { name: "Shen Pei", org: "Wanwuhuanxin", image: "/assets/alliance/shen-pei.png", type: "avatar" },
  { name: "Jane Yao", org: "Baqian Law", image: "/assets/alliance/jane-yao.png", type: "avatar" },
  { name: "AliceLuo", org: "WeOPC", image: "/assets/alliance/alice-luo.png", type: "avatar" },
  { name: "Lotte Huang", org: "Macau University of Science and Technology", image: "/assets/alliance/lotte-huang.png", type: "avatar" },
  { name: "Wenjun Yuan", org: "AI Matrix Seo Agent", image: "/assets/alliance/wenjun-yuan.png", type: "logo" },
  { name: "LimitlessChallenge", org: "Freelancer", image: "/assets/alliance/limitlesschallenge.png", type: "avatar" },
  { name: "Design LIN", org: "Freelancer", image: "/assets/alliance/design-lin.png", type: "avatar" },
  { name: "AuraBaba 灵光爸爸", image: "/assets/alliance/aurababa.png", type: "logo" },
  { name: "OpenAI", image: "/assets/alliance/openai.png", type: "logo" },
  { name: "Anthropic", image: "/assets/alliance/anthropic.png", type: "logo" },
  { name: "NVIDIA", image: "/assets/alliance/nvidia.png", type: "logo" },
  { name: "Palantir", image: "/assets/alliance/palantir.svg", type: "logo" },
  { name: "Elon Musk", org: "xAI / Tesla", image: "/assets/alliance/elon-musk.png", type: "avatar" },
  { name: "EPFL", image: "/assets/alliance/epfl.png", type: "logo" },
  { name: "PHBern", image: "/assets/alliance/phbern.png", type: "logo" },
];

const allianceMarquee = [...allianceMembers, ...allianceMembers];
const allianceMemberCount = allianceMembers.length;
---

<SiteLayout title="FDE FAN Academy | AI Agent FDE 前端部署工程师学习站" description="FDE FAN Academy 将课程、案例、项目和企业 AI 转型诊断 Agent 融合，训练学员完成 Prompt、前端 Demo、Agent 工作流、部署链接和交付文档。">
  <section class="home-hero">
    <div class="grid-mask"></div>
    <div class="hero-copy">
      <p class="eyebrow">AI-FDE x Industry Agents x Deployment</p>
      <h1 class="hero-title">FDE FAN</h1>
      <p class="hero-subtitle">
        <span class="zh">AI-FDE 前端部署工程师学习站</span>
        <span class="en">AI Front-End Deployment Engineer Academy</span>
      </p>
      <p class="hero-text">
        <span class="zh">从业务意图、上下文工程、工具权限、Agent 工作流、评估审计到部署交付，训练学员把企业需求转成可验证的 AI 应用。</span>
        <span class="en">Train intent framing, context engineering, tool access, agent workflow, evaluation, audit, and deployment for verifiable AI applications.</span>
      </p>
      <div class="hero-actions">
        <a class="cta-primary" href="/learn"><span class="zh">开始学习 FDE 路径</span><span class="en">Start the FDE Path</span></a>
        <a class="cta-secondary" href="/tools/diagnosis"><span class="zh">体验企业 AI 转型诊断</span><span class="en">Try AI Transformation Diagnosis</span></a>
      </div>
      <div class="stat-row">
        {stats.map(([value, zh, en]) => (
          <div>
            <strong>{value}</strong>
            <span class="zh">{zh}</span>
            <span class="en">{en}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="hero-console" aria-label="FDE delivery flow">
      <div class="console-top"><span></span><span></span><span></span><b>LIVE TRAINING OPS</b></div>
      <div class="terminal-line">intent -&gt; context -&gt; ontology -&gt; tools</div>
      <div class="terminal-line active">branch -&gt; eval -&gt; review -&gt; deploy -&gt; audit</div>
      <div class="ops-rail">
        {weekPath.slice(0, 6).map(([week, zh, en]) => (
          <div><b>{week}</b><span class="zh">{zh}</span><span class="en">{en}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-wrap band">
    <div class="section-heading">
      <p class="eyebrow">AI-FDE LOOP</p>
      <h2><span class="zh">向真实 AI-FDE 靠拢：不是聊天，是受控交付闭环。</span><span class="en">Closer to real AI-FDE work: not chatting, but controlled delivery loops.</span></h2>
      <p><span class="zh">借鉴企业级 AI-FDE 的工作方式，课程强化意图、上下文、权限、工具、验证、评审和审计，让学员知道什么时候该让 AI 做，什么时候必须人审和回退。</span><span class="en">Inspired by enterprise AI-FDE practice, the curriculum emphasizes intent, context, access, tools, validation, review, and audit.</span></p>
    </div>
    <div class="loop-grid">
      {aiFdeLoop.map((item) => (
        <div class="loop-card">
          <span>{item.mark}</span>
          <h3><span class="zh">{item.zh}</span><span class="en">{item.en}</span></h3>
          <p><span class="zh">{item.text}</span><span class="en">{item.textEn}</span></p>
        </div>
      ))}
    </div>
  </section>

  <section class="section-wrap">
    <div class="section-heading">
      <p class="eyebrow">ACADEMY SYSTEM</p>
      <h2><span class="zh">像 W3Schools 一样清晰，但面向真实交付。</span><span class="en">Structured like a learning site. Built for real delivery.</span></h2>
      <p><span class="zh">FDE FAN 不只展示课程大纲，而是把教程、案例、练习、项目任务书和交付模板放进同一个学习系统。</span><span class="en">FDE FAN combines tutorials, cases, exercises, project briefs, and delivery templates into one practical learning system.</span></p>
    </div>
    <div class="track-grid">
      {learningTracks.map((track) => (
        <a class="track-card" href={track.href}>
          <span class="card-mark">{track.mark}</span>
          <h3><span class="zh">{track.zh}</span><span class="en">{track.en}</span></h3>
          <p><span class="zh">{track.summary}</span><span class="en">{track.summaryEn}</span></p>
        </a>
      ))}
    </div>
  </section>

  <section class="section-wrap band">
    <div class="section-heading">
      <p class="eyebrow">VERTICAL LABS</p>
      <h2><span class="zh">把垂直行业独立出来，做成可复用解决方案。</span><span class="en">Separate vertical industries into reusable solution labs.</span></h2>
      <p><span class="zh">跨境电商来自 OPC 工具矩阵和链主资源；文旅面向景区、酒店、旅行社、文博场馆和目的地运营。</span><span class="en">Commerce is grounded in the OPC tool matrix; culture-tourism covers attractions, hotels, agencies, museums, and destination operations.</span></p>
    </div>
    <div class="industry-hero-grid">
      {industryLabs.map((lab) => (
        <a class="industry-card" href={lab.href}>
          <span class="card-mark">{lab.mark}</span>
          <h3><span class="zh">{lab.zh}</span><span class="en">{lab.en}</span></h3>
          <p><span class="zh">{lab.summary}</span><span class="en">{lab.summaryEn}</span></p>
          <div class="chip-row">
            {lab.signals.slice(0, 8).map((signal) => <span>{signal}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section-wrap band">
    <div class="section-heading">
      <p class="eyebrow">WHAT FDE SHIPS</p>
      <h2><span class="zh">最后不是证书，是可展示的交付链路。</span><span class="en">The output is not a slogan. It is a delivery chain.</span></h2>
    </div>
    <div class="outcome-grid">
      {outcomes.map((item) => (
        <div class="metric-card">
          <b>{item.mark}</b>
          <span class="zh">{item.text}</span>
          <span class="en">{item.en}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section-wrap">
    <div class="section-heading">
      <p class="eyebrow">REAL TOOL</p>
      <h2><span class="zh">企业 AI 转型诊断 Agent 已纳入课程主线。</span><span class="en">The AI transformation diagnosis agent becomes a core case.</span></h2>
      <p><span class="zh">它不是摆设，而是学员会拆解、复刻和升级的真实企业 Agent：多轮访谈、画像抽取、机会地图、成熟度评分和 30/60/90 天路线图。</span><span class="en">Learners study, rebuild, and improve a real enterprise agent: interview, profile extraction, opportunity map, maturity scoring, and 30/60/90-day roadmap.</span></p>
    </div>
    <a class="diagnosis-banner" href="/diagnosis">
      <span>fde.fan/diagnosis</span>
      <strong><span class="zh">打开诊断工具说明</span><span class="en">Open diagnosis tool brief</span></strong>
    </a>
  </section>

  <section class="section-wrap band">
    <div class="section-heading">
      <p class="eyebrow">ASSESSMENT</p>
      <h2><span class="zh">评分、分层与后续路径</span><span class="en">Assessment, levels, and next paths</span></h2>
    </div>
    <div class="level-grid">
      {assessmentLevels.map(([level, score, zh, en]) => (
        <div class="level-card">
          <strong>{level}</strong>
          <span>{score}</span>
          <p class="zh">{zh}</p>
          <p class="en">{en}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section-wrap">
    <div class="boundary-panel">
      <h2><span class="zh">清晰边界，可信招生。</span><span class="en">Clear boundaries, credible enrollment.</span></h2>
      <div>
        {boundaryItems.map((item) => (
          <p><span>OK</span>{item}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="alliance-section" aria-label="FDE alliance members">
    <div class="alliance-heading">
      <p class="eyebrow">FDE ALLIANCE</p>
      <h2><span class="zh">FDE 联盟成员</span><span class="en">FDE Alliance Members</span></h2>
    </div>
    <div class="alliance-marquee">
      <div class="alliance-track" data-alliance-track data-member-count={allianceMemberCount}>
        {allianceMarquee.map((member) => (
          <div class="alliance-item">
            <span class={`alliance-logo ${member.type}`}>
              <img src={member.image} alt={`${member.name} logo`} loading="lazy" />
            </span>
            <span class="alliance-copy">
              <strong>{member.name}</strong>
              {member.org && <small>{member.org}</small>}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const track = document.querySelector("[data-alliance-track]");
    if (track instanceof HTMLElement) {
      const count = Number(track.dataset.memberCount || 0);
      const sourceItems = Array.from(track.children).slice(0, count);
      for (let index = sourceItems.length - 1; index > 0; index -= 1) {
        const swapIndex = Math.floor(Math.random() * (index + 1));
        [sourceItems[index], sourceItems[swapIndex]] = [sourceItems[swapIndex], sourceItems[index]];
      }
      const firstLoop = sourceItems.map((item) => item.cloneNode(true));
      const secondLoop = sourceItems.map((item) => item.cloneNode(true));
      track.replaceChildren(...firstLoop, ...secondLoop);
    }
  </script>
</SiteLayout>
