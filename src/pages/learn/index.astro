---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import DocShell from "../../components/DocShell.astro";
import { aiFdeLoop, learningTracks, weekPath } from "../../data/site";

const tutorials = (await getCollection("tutorials")).sort((a, b) => a.data.order - b.data.order);
---

<SiteLayout title="FDE FAN Learn | 课程总目录" description="FDE FAN Academy 课程总目录，围绕 Codex、Claude Code、Antigravity、Cursor 等 AI 工具组织 Forward Deployed Engineer 学习路径。">
  <DocShell eyebrow="LEARN" title="AI 工具驱动的 FDE 学习路径" titleEn="AI-Tool-Driven FDE Learning Path" description="所有训练都围绕 AI 工具应用展开：理解必要技术概念，是为了更好地指挥工具完成需求、Demo、Agent、部署、评估和交付。" descriptionEn="All training is organized around AI tool application. Technical concepts are learned only to better direct tools for requirements, demos, agents, deployment, evaluation, and delivery.">
    <h2>AI-FDE 工作闭环</h2>
    <div class="loop-grid compact">
      {aiFdeLoop.map((item) => (
        <div class="loop-card">
          <span>{item.mark}</span>
          <h3><span class="zh">{item.zh}</span><span class="en">{item.en}</span></h3>
          <p><span class="zh">{item.text}</span><span class="en">{item.textEn}</span></p>
        </div>
      ))}
    </div>
    <section class="content-grid">
      {learningTracks.map((track) => (
        <a class="doc-card" href={track.href}>
          <h2><span class="zh">{track.zh}</span><span class="en">{track.en}</span></h2>
          <p><span class="zh">{track.summary}</span><span class="en">{track.summaryEn}</span></p>
        </a>
      ))}
    </section>
    <h2>8 周训练路径</h2>
    <div class="timeline">
      {weekPath.map(([week, zh, en]) => (
        <a href="/projects">
          <strong>{week}</strong>
          <span class="zh">{zh}</span>
          <span class="en">{en}</span>
        </a>
      ))}
    </div>
    <h2>12 篇基础教程</h2>
    <div class="resource-list">
      {tutorials.map((entry) => (
        <a href={`/learn/tutorials/${entry.slug}`}>
          <b><span class="zh">{entry.data.title}</span><span class="en">{entry.data.titleEn}</span></b>
          <span class="zh">{entry.data.summary}</span>
          <span class="en">{entry.data.summaryEn}</span>
        </a>
      ))}
    </div>
  </DocShell>
</SiteLayout>
