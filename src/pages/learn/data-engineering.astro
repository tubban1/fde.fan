---
import SiteLayout from "../../layouts/SiteLayout.astro";
import RoadmapModulePage from "../../components/RoadmapModulePage.astro";
import { breadcrumbJsonLd, courseJsonLd } from "../../lib/seo";
import { discoveryChecklist, roadmapModules } from "../../data/roadmap";

const module = roadmapModules.find((item) => item.slug === "data-engineering")!;
const checklist = discoveryChecklist.filter((item) => item.group === "数据与安全");
---

<SiteLayout
  title="AI-Assisted Data Handling | FDE FAN"
  description="FDE AI 工具数据处理课程：用 Codex、Claude Code、Cursor 等工具处理 Excel、CSV、飞书表格和 ERP 导出，生成字段字典、清洗脚本和数据说明。"
  jsonLd={[
    breadcrumbJsonLd([
      { name: "FDE FAN", path: "/" },
      { name: "Learn", path: "/learn" },
      { name: "AI Data Handling", path: "/learn/data-engineering" },
    ]),
    courseJsonLd({ name: "AI-Assisted Data Handling for Forward Deployed Engineers", description: module.summary, path: module.href }),
  ]}
>
  <RoadmapModulePage
    module={module}
    checklist={checklist}
    extraIntro="FDE 进入企业现场，经常先面对一堆 Excel、CSV、ERP 导出和口径不一致的指标。本章不是培养数据工程师，而是训练学员会用 AI 工具快速整理、解释和验证数据。"
    extraIntroEn="In the field, an FDE often starts with Excel files, CSV exports, ERP dumps, and conflicting metric definitions. This chapter does not train data engineers; it trains learners to use AI tools to organize, explain, and verify data."
  />
</SiteLayout>
