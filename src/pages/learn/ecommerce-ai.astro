---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import DocShell from "../../components/DocShell.astro";

const commerceCategories = new Set(["Diagnosis", "Marketing", "Support", "Operations", "Content", "Advisory", "Analytics"]);
const cases = (await getCollection("cases")).filter((entry) => commerceCategories.has(entry.data.category));
---

<SiteLayout title="Cross-border AI Cases | FDE FAN" description="跨境电商 AI 场景课程：客服、商品、广告、TikTok 内容矩阵、运营诊断。">
  <DocShell eyebrow="CROSS-BORDER AI" title="跨境电商 AI 课程" titleEn="Cross-Border AI Course" description="课程页保留方法训练；完整行业工具矩阵、OPC 服务包和链主资源请进入跨境电商行业实验室。" descriptionEn="This course page focuses on methods. Use the industry lab for the full commerce tool matrix and delivery playbook.">
    <div class="note-panel">
      <strong>行业实验室</strong>
      <p>跨境电商已独立为垂直行业页，覆盖选品、POD、AI 内容、数字人、投放、达人、ERP、本地化、IP 安全、RPA、BI、合规、金融和客服。</p>
      <a class="cta-secondary" href="/industries/cross-border-commerce">打开跨境电商 AI 工具矩阵</a>
    </div>
    <div class="content-grid">
      {cases.map((entry) => (
        <a class="doc-card" href={`/cases/${entry.slug}`}>
          <span class="tag">{entry.data.category}</span>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.deliverables.join(" / ")}</p>
        </a>
      ))}
    </div>
  </DocShell>
</SiteLayout>
