---
import SiteLayout from "../../layouts/SiteLayout.astro";
import RoadmapModulePage from "../../components/RoadmapModulePage.astro";
import { breadcrumbJsonLd, courseJsonLd } from "../../lib/seo";
import { discoveryChecklist, roadmapModules } from "../../data/roadmap";

const module = roadmapModules.find((item) => item.slug === "cloud-deployment")!;
const checklist = discoveryChecklist.filter((item) => item.group === "基础设施");
---

<SiteLayout
  title="AI-Assisted Deployment and Operations | FDE FAN"
  description="FDE AI 工具部署运行课程：用 Codex、Claude Code、Antigravity、Cursor 协助部署、看日志、解释报错、检查环境变量和写回滚步骤。"
  jsonLd={[
    breadcrumbJsonLd([
      { name: "FDE FAN", path: "/" },
      { name: "Learn", path: "/learn" },
      { name: "AI Deployment", path: "/learn/cloud-deployment" },
    ]),
    courseJsonLd({ name: "AI-Assisted Deployment and Operations for FDE", description: module.summary, path: module.href }),
  ]}
>
  <RoadmapModulePage
    module={module}
    checklist={checklist}
    extraIntro="中文版作业不做云厂商底层专精。我们用阿里云、本地服务、Vercel、内网 API 等常见场景，让学员学会把报错、日志、环境变量和回滚步骤交给 AI 工具协助处理。"
    extraIntroEn="Assignments do not dive into cloud-provider internals. We use common scenarios such as Alibaba Cloud, local services, Vercel, and private APIs so learners can ask AI tools to handle errors, logs, env vars, and rollback steps."
  />
</SiteLayout>
