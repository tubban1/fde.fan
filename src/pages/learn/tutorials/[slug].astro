---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import DocShell from "../../../components/DocShell.astro";
import { breadcrumbJsonLd, courseJsonLd } from "../../../lib/seo";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("tutorials");
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const pagePath = `/learn/tutorials/${entry.slug}`;
const jsonLd = [
  breadcrumbJsonLd([
    { name: "FDE FAN", path: "/" },
    { name: "Learn", path: "/learn" },
    { name: entry.data.title, path: pagePath },
  ]),
  courseJsonLd({
    name: `${entry.data.title} / ${entry.data.titleEn}`,
    description: entry.data.summary,
    path: pagePath,
  }),
];
---

<SiteLayout title={`${entry.data.title} | FDE FAN`} description={entry.data.summary} jsonLd={jsonLd}>
  <DocShell eyebrow={entry.data.track.toUpperCase()} title={entry.data.title} titleEn={entry.data.titleEn} description={entry.data.summary} descriptionEn={entry.data.summaryEn}>
    <Content />
  </DocShell>
</SiteLayout>
