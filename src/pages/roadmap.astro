---
import SiteLayout from "../layouts/SiteLayout.astro";
import DocShell from "../components/DocShell.astro";
import { articleJsonLd, breadcrumbJsonLd } from "../lib/seo";
import { caseStudyReferences, diagnosticQuestions, discoveryChecklist, roadmapLayers } from "../data/roadmap";

const title = "FDE FAN Roadmap | 系统化 Forward Deployed Engineer 学习路线图";
const description = "FDE FAN 系统化路线图：围绕 Codex、Claude Code、Antigravity、Cursor 等 AI 工具，训练前线部署工程师完成需求、Demo、Agent、部署、评估和交付。";
---

<SiteLayout
  title={title}
  description={description}
  keywords="FDE Roadmap, Forward Deployed Engineer, 前线部署工程师, AI-FDE, Agent Evaluation, Diagnostic Mindset"
  jsonLd={[
    breadcrumbJsonLd([
      { name: "FDE FAN", path: "/" },
      { name: "Roadmap", path: "/roadmap" },
    ]),
    articleJsonLd({ headline: title, description, path: "/roadmap" }),
  ]}
>
  <DocShell
    eyebrow="SYSTEM ROADMAP"
    title="系统化 FDE 学习路线图"
    titleEn="Systematic FDE Learning Roadmap"
    description="这里不是课程目录，而是 FDE 能力地图：解释为什么要学 AI 工具、交付闭环、企业判断、行业场景和模板资产。具体上课入口在 Learn。"
    descriptionEn="This is not the course directory. It is the FDE capability map: why AI tools, delivery loops, field judgment, industry scenarios, and templates matter. Use Learn for course entry."
  >
    <h2><span class="zh">四层能力架构</span><span class="en">Four-Layer Capability Architecture</span></h2>
    <div class="loop-grid compact">
      {roadmapLayers.map((layer) => (
        <div class="loop-card">
          <span>{layer.mark}</span>
          <h3><span class="zh">{layer.titleZh}</span><span class="en">{layer.title}</span></h3>
          <p><span class="zh">{layer.body}</span><span class="en">{layer.bodyEn}</span></p>
        </div>
      ))}
    </div>

    <section class="insight-lesson">
      <p class="eyebrow">COURSE ENTRY</p>
      <p>
        <span class="zh">如果你已经理解能力全景，下一步进入 Learn，按阶段完成课程和项目。</span>
        <span class="en">Once you understand the capability map, move to Learn and complete lessons and projects by stage.</span>
      </p>
      <a class="cta-secondary" href="/learn">进入学习路径</a>
    </section>

    <h2><span class="zh">Diagnostic Mindset：FDE 的三问</span><span class="en">Diagnostic Mindset: The Three Whys</span></h2>
    <div class="assignment-list">
      {diagnosticQuestions.map((item, index) => (
        <div>
          <b>{String(index + 1).padStart(2, "0")}</b>
          <p>
            <strong><span class="zh">{item.q}</span><span class="en">{item.qEn}</span></strong><br />
            <span class="zh">{item.a}</span><span class="en">{item.aEn}</span>
          </p>
        </div>
      ))}
    </div>

    <h2><span class="zh">Forward Deployment Discovery Checklist</span><span class="en">Forward Deployment Discovery Checklist</span></h2>
    <div class="deep-section-list">
      {discoveryChecklist.map((group) => (
        <section class="deep-section">
          <h3><span class="zh">{group.group}</span><span class="en">{group.groupEn}</span></h3>
          <ul>
            {group.items.map(([zh, en]) => (
              <li><span class="zh">{zh}</span><span class="en">{en}</span></li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <h2><span class="zh">Case Study 参考</span><span class="en">Case Study References</span></h2>
    <div class="resource-list">
      {caseStudyReferences.map((item) => (
        <a href={item.href} target="_blank" rel="noreferrer">
          <b>{item.title}</b>
          <span class="zh">{item.lesson}</span>
          <span class="en">{item.lessonEn}</span>
        </a>
      ))}
    </div>

    <h2><span class="zh">Artifact Templates</span><span class="en">Artifact Templates</span></h2>
    <section class="insight-lesson">
      <p class="eyebrow">TEMPLATE LIBRARY</p>
      <p>
        <span class="zh">完整模板集中放在 Artifact Templates 页面，避免同一批模板在 Roadmap、Resources 和 Templates 多处重复维护。</span>
        <span class="en">The full template library lives on the Artifact Templates page to avoid maintaining the same templates across Roadmap, Resources, and Templates.</span>
      </p>
      <a class="cta-secondary" href="/templates">Open Artifact Templates</a>
    </section>
  </DocShell>
</SiteLayout>
