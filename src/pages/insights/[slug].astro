---
import SiteLayout from "../../layouts/SiteLayout.astro";
import DocShell from "../../components/DocShell.astro";
import InsightVisual from "../../components/InsightVisual.astro";
import { insightArticles, insightDeepDives } from "../../data/insights";

export const prerender = true;

export function getStaticPaths() {
  return insightArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const deepDive = insightDeepDives[article.slug];
---

<SiteLayout title={`${article.titleEn} | FDE FAN Insights`} description={article.abstract}>
  <DocShell
    eyebrow="INSIGHT BRIEF"
    title={article.title}
    titleEn={article.titleEn}
    description={article.abstract}
    descriptionEn={article.abstractEn}
    links={[
      { href: "/insights", label: "专业洞察" },
      { href: article.sourceUrl, label: "Reference" },
    ]}
  >
    <div class="source-strip">
      <div>
        <span class="zh">参考资料</span>
        <span class="en">Reference</span>
        <strong>{article.sourcePublisher}</strong>
      </div>
      <a href={article.sourceUrl} target="_blank" rel="noreferrer">{article.sourceTitle}</a>
      <small>{article.dateLabel}</small>
    </div>

    <div class="insight-note">
      <b><span class="zh">学习说明</span><span class="en">Learning Note</span></b>
      <p>
        <span class="zh">本页以 FDE FAN 的第一视角讲解知识：先讲概念，再讲方法、图表、训练任务。底部保留参考来源，方便继续阅读。</span>
        <span class="en">This page teaches in FDE FAN's own voice: concepts first, then methods, visuals, and practice tasks. References are kept at the bottom for further reading.</span>
      </p>
    </div>

    <InsightVisual type={article.figure} />

    {deepDive && (
      <>
        <h2><span class="zh">知识结构地图</span><span class="en">Knowledge Structure Map</span></h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th><span class="zh">知识层级</span><span class="en">Knowledge Layer</span></th>
                <th><span class="zh">我们要掌握什么</span><span class="en">What We Need to Master</span></th>
                <th><span class="zh">训练产物</span><span class="en">Training Artifact</span></th>
              </tr>
            </thead>
            <tbody>
              {deepDive.sourceMap.map((row, index) => (
                <tr>
                  <td><span class="zh">{row[0]}</span><span class="en">{deepDive.sourceMapEn[index][0]}</span></td>
                  <td><span class="zh">{row[1]}</span><span class="en">{deepDive.sourceMapEn[index][1]}</span></td>
                  <td><span class="zh">{row[2]}</span><span class="en">{deepDive.sourceMapEn[index][2]}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}

    <h2><span class="zh">核心观点</span><span class="en">Key Takeaways</span></h2>
    <div class="takeaway-list">
      {article.takeaways.map((item, index) => (
        <div>
          <b>{String(index + 1).padStart(2, "0")}</b>
          <p><span class="zh">{item}</span><span class="en">{article.takeawaysEn[index]}</span></p>
        </div>
      ))}
    </div>

    <h2><span class="zh">{article.tableTitle}</span><span class="en">{article.tableTitleEn}</span></h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><span class="zh">层级</span><span class="en">Layer</span></th>
            <th><span class="zh">含义</span><span class="en">Meaning</span></th>
            <th><span class="zh">FDE 产物</span><span class="en">FDE Artifact</span></th>
          </tr>
        </thead>
        <tbody>
          {article.rows.map((row, index) => (
            <tr>
              <td><span class="zh">{row[0]}</span><span class="en">{article.rowsEn[index][0]}</span></td>
              <td><span class="zh">{row[1]}</span><span class="en">{article.rowsEn[index][1]}</span></td>
              <td><span class="zh">{row[2]}</span><span class="en">{article.rowsEn[index][2]}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {deepDive && (
      <>
        <h2><span class="zh">深度讲义</span><span class="en">Deep Study Notes</span></h2>
        <div class="deep-section-list">
          {deepDive.sections.map((section) => (
            <section class="deep-section">
              <h3><span class="zh">{section.title}</span><span class="en">{section.titleEn}</span></h3>
              <p><span class="zh">{section.body}</span><span class="en">{section.bodyEn}</span></p>
            </section>
          ))}
        </div>
      </>
    )}

    <section class="insight-lesson">
      <p class="eyebrow"><span class="zh">本课训练目标</span><span class="en">Training Goal</span></p>
      <p><span class="zh">{article.fdeLesson}</span><span class="en">{article.fdeLessonEn}</span></p>
    </section>

    {deepDive && (
      <>
        <h2><span class="zh">课堂任务</span><span class="en">Classroom Assignments</span></h2>
        <div class="assignment-list">
          {deepDive.assignments.map((item, index) => (
            <div>
              <b>{String(index + 1).padStart(2, "0")}</b>
              <p><span class="zh">{item}</span><span class="en">{deepDive.assignmentsEn[index]}</span></p>
            </div>
          ))}
        </div>
      </>
    )}

    <section class="citation-box">
      <h2><span class="zh">引用</span><span class="en">Citation</span></h2>
      <p>
        {article.sourcePublisher}. <i>{article.sourceTitle}</i>. {article.sourceUrl}. {article.dateLabel}.
      </p>
    </section>
  </DocShell>
</SiteLayout>
