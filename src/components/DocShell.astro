---
interface Props {
  eyebrow: string;
  title: string;
  titleEn: string;
  description: string;
  descriptionEn: string;
  links?: { href: string; label: string }[];
}

const { eyebrow, title, titleEn, description, descriptionEn, links = [] } = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const normalizeHref = (href: string) => href.replace(/\/$/, "") || "/";
const isActive = (href: string) => normalizeHref(href) === currentPath;
const isInSection = (items: { href: string }[]) =>
  items.some((item) => {
    const href = normalizeHref(item.href);
    return currentPath === href || currentPath.startsWith(`${href}/`);
  });

const menuGroups = [
  {
    label: "学习",
    labelEn: "Learn",
    items: [
      { href: "/roadmap", label: "系统路线图", labelEn: "Roadmap" },
      { href: "/learn", label: "学习路径", labelEn: "Learning Path" },
      { href: "/learn/what-is-fde", label: "FDE 是什么", labelEn: "What Is FDE" },
      { href: "/learn/foundations", label: "基础", labelEn: "Foundations" },
      { href: "/learn/data-engineering", label: "AI 数据处理", labelEn: "AI Data Handling" },
      { href: "/learn/cloud-deployment", label: "AI 部署运行", labelEn: "AI Deployment" },
      { href: "/learn/prompt-to-ui", label: "Prompt 到页面", labelEn: "Prompt to UI" },
      { href: "/learn/agent-workflows", label: "Agent 工作流", labelEn: "Agent Workflows" },
      { href: "/learn/evaluation", label: "AI 评估", labelEn: "Evaluation" },
      { href: "/learn/consulting", label: "Soft Stack", labelEn: "Soft Stack" },
      { href: "/learn/ecommerce-ai", label: "跨境 AI", labelEn: "Ecommerce AI" },
      { href: "/learn/deployment", label: "部署", labelEn: "Deployment" },
      { href: "/glossary/fde", label: "FDE 词条", labelEn: "FDE Glossary" },
    ],
  },
  {
    label: "行业",
    labelEn: "Industries",
    items: [
      { href: "/industries", label: "行业实验室", labelEn: "Industry Labs" },
      { href: "/industries/cross-border-commerce", label: "跨境电商", labelEn: "Cross-border Commerce" },
      { href: "/industries/culture-tourism", label: "文旅 AI", labelEn: "Culture Tourism" },
    ],
  },
  {
    label: "案例与研究",
    labelEn: "Cases & Research",
    items: [
      { href: "/cases", label: "案例库", labelEn: "Cases" },
      { href: "/insights", label: "专业洞察", labelEn: "Insights" },
      { href: "/insights/hfs-ai-fde-flywheel", label: "AI 飞轮", labelEn: "AI Flywheel" },
      { href: "/insights/unframe-context-platform", label: "上下文平台", labelEn: "Context Platform" },
      { href: "/insights/perspective-2026-tool-stack", label: "工具栈", labelEn: "Tool Stack" },
      { href: "/insights/invisible-forward-deployed-engineering", label: "FDE 岗位", labelEn: "FDE Role" },
      { href: "/insights/kamechi-ai-ux-workshop", label: "AI UX 工作坊", labelEn: "AI UX Workshop" },
    ],
  },
  {
    label: "交付",
    labelEn: "Delivery",
    items: [
      { href: "/projects", label: "项目题库", labelEn: "Projects" },
      { href: "/resources", label: "资源模板", labelEn: "Resources" },
      { href: "/templates", label: "Artifact Templates", labelEn: "Artifact Templates" },
      { href: "/assessment", label: "评分体系", labelEn: "Assessment" },
      { href: "/tools/diagnosis", label: "诊断工具", labelEn: "Diagnosis Tool" },
    ],
  },
];

const pageLinks = links.map((link) => ({ href: link.href, label: link.label, labelEn: link.label }));
---

<section class="doc-hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1><span class="zh">{title}</span><span class="en">{titleEn}</span></h1>
  <p><span class="zh">{description}</span><span class="en">{descriptionEn}</span></p>
</section>
<div class="doc-layout">
  <aside class="doc-sidebar" aria-label="文档导航">
    {menuGroups.map((group) => (
      <details class="sidebar-group" open={isInSection(group.items)}>
        <summary>
          <span class="zh">{group.label}</span>
          <span class="en">{group.labelEn}</span>
        </summary>
        <div class="sidebar-group-links">
          {group.items.map((item) => (
            <a href={item.href} class={isActive(item.href) ? "active" : ""} aria-current={isActive(item.href) ? "page" : undefined}>
              <span class="zh">{item.label}</span>
              <span class="en">{item.labelEn}</span>
            </a>
          ))}
        </div>
      </details>
    ))}
    {pageLinks.length > 0 && (
      <details class="sidebar-group" open>
        <summary>
          <span class="zh">本页</span>
          <span class="en">This Page</span>
        </summary>
        <div class="sidebar-group-links">
          {pageLinks.map((link) => (
            <a href={link.href} class={isActive(link.href) ? "active" : ""} aria-current={isActive(link.href) ? "page" : undefined}>
              <span class="zh">{link.label}</span>
              <span class="en">{link.labelEn}</span>
            </a>
          ))}
        </div>
      </details>
    )}
  </aside>
  <article class="doc-content">
    <slot />
  </article>
</div>
